pipeline {
    agent any

    tools {
        jdk 'jdk21'
        gradle 'gradle8'
    }

    environment {
        DOCKER_HUB_USERNAME = 'octavian2508'
        DOCKER_PASSWORD = credentials('docker_password')
        GITHUB_TOKEN = credentials('github_token')
    }

    stages {
        stage('Build') {
            steps {
                sh './gradlew clean build'
            }
        }

        stage('Test') {
            steps {
                sh './gradlew test'
            }
        }

        stage('Version & Tag') {
            steps {
                script {
                    sh 'git fetch --tag'
                    env.MAJOR_VERSION = sh(
                        script: 'git tag | sort -V | tail -1 | cut -d . -f 1',
                        returnStdout: true
                    ).trim()
                    env.MINOR_VERSION = sh(
                        script: 'git tag | sort -V | tail -1 | cut -d . -f 2',
                        returnStdout: true
                    ).trim()
                    env.PATCH_VERSION = sh(
                        script: 'git tag | sort -V | tail -1 | cut -d . -f 3',
                        returnStdout: true
                    ).trim()
                    def minorInt = env.MINOR_VERSION.toInteger()
                    env.IMAGE_TAG = "${env.MAJOR_VERSION}.${minorInt + 1}.${env.PATCH_VERSION}"
                    echo "Building version: ${env.IMAGE_TAG}"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                // UPDATED: Using absolute path for docker
                sh '/usr/local/bin/docker build -t $DOCKER_HUB_USERNAME/prod-eng-img:$IMAGE_TAG .'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                // UPDATED: Using absolute path for docker login and push
                sh '''
                    echo $DOCKER_PASSWORD_PSW | /usr/local/bin/docker login -u $DOCKER_HUB_USERNAME --password-stdin
                    /usr/local/bin/docker push $DOCKER_HUB_USERNAME/prod-eng-img:$IMAGE_TAG
                '''
            }
        }

        stage('Deploy Application') {
            steps {
                script {
                    // UPDATED: Using absolute path for docker ps and docker stop
                    sh '''
                        /usr/local/bin/docker ps -q --filter "name=prod-eng" | xargs -r /usr/local/bin/docker stop
                        /usr/local/bin/docker ps -q --filter "name=mongo" | xargs -r /usr/local/bin/docker stop
                    '''
                    // UPDATED: Using absolute path for docker compose
                    sh """
                        PROD_ENG_IMAGE=${DOCKER_HUB_USERNAME}/prod-eng-img:${env.IMAGE_TAG} /usr/local/bin/docker compose up -d prod-eng mongo
                    """
                    sleep 30
                }
            }
        }

        stage('Integration Tests') {
            steps {
                sh 'MONGODB_CONECTION_URL=mongodb://root:example@host.docker.internal:27017 ./gradlew testIT'
            }
        }

        stage('Tag Release') {
            steps {
                sh '''
                    git tag $IMAGE_TAG
                    git push https://$GITHUB_TOKEN_PSW@github.com/FilipOctavian/prod-engineering.git $IMAGE_TAG
                '''
            }
        }
    }

    post {
        always {
            junit '**/build/test-results/**/*.xml'
            publishHTML([
                allowMissing: true,
                alwaysLinkToLastBuild: false,
                keepAll: true,
                reportDir: 'build/reports/tests/test',
                reportFiles: 'index.html',
                reportName: 'Test Report'
            ])
            // UPDATED: Using absolute path for docker logout
            sh '/usr/local/bin/docker logout'
        }
    }
}
